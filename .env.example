# Telegram bot (optional - only needed for `--alert` flags)
# Create a bot via @BotFather, get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Database
POLYWHALE_DB_PATH=data/polywhale.sqlite

# Alerts: true = only notify on OUR copy trades (opens/closes); false = full
# whale-activity firehose (every detected whale move). Default true.
POLYWHALE_ALERT_COPY_ONLY=true

# Logging
POLYWHALE_LOG_LEVEL=INFO
